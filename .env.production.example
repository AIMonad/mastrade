# Production Environment Variables
# Copy this to .env.production and fill in your values

# Backend Configuration
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=your-secret-key-here-min-32-chars-change-this

# Database
DATABASE_URL=sqlite:////data/mastrade.db

# Frontend Configuration
NEXT_PUBLIC_API_URL=/api
NODE_ENV=production

# Traefik Configuration
DOMAIN_NAME=your_vps_ip_or_domain.com
CERTIFICATE_EMAIL=your-email@example.com

# Traefik - Cloudflare DNS Challenge (Optional)
# Uncomment and fill if using Cloudflare for domain
# CF_API_EMAIL=your-cloudflare-email@example.com
# CF_API_KEY=your-cloudflare-api-key
